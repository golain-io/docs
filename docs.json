{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Golain",
  "description": "Documentation for the Golain IoT platform — console, CLI, edge runtime, and self-hosted deployment.",
  "colors": {
    "primary": "#7F12B2",
    "light": "#5BEB9D",
    "dark": "#5A0D82"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/golain-io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Console",
      "href": "https://app.golain.io"
    }
  },
  "api": {
    "openapi": "api-reference/ilyama.v1.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript", "go"],
      "defaults": "required"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Platform",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "getting-started/quickstart",
              "getting-started/concepts",
              "getting-started/choose-your-path"
            ]
          },
          {
            "group": "Console",
            "pages": [
              "console/overview",
              "console/fleets-and-devices",
              "console/ota",
              "console/integrations",
              "console/settings"
            ]
          }
        ]
      },
      {
        "tab": "Tools",
        "groups": [
          {
            "group": "Platform CLI (platform-tui)",
            "pages": [
              "tools/platform-tui/overview",
              "tools/platform-tui/install",
              "tools/platform-tui/login",
              "tools/platform-tui/context",
              "tools/platform-tui/cli-reference",
              "tools/platform-tui/tui-guide"
            ]
          },
          {
            "group": "Golain CLI",
            "pages": [
              "tools/golain-cli/overview",
              "tools/golain-cli/install",
              "tools/golain-cli/commands"
            ]
          }
        ]
      },
      {
        "tab": "Edge",
        "groups": [
          {
            "group": "Omega edge runtime",
            "pages": [
              "edge/overview",
              "edge/install",
              "edge/configure",
              "edge/connect",
              "edge/jitr",
              "edge/deploy",
              "edge/remote-control"
            ]
          },
          {
            "group": "Edge SQLite sync",
            "pages": [
              "edge/data-sync/overview",
              "edge/data-sync/how-it-works",
              "edge/data-sync/lineages-and-staging",
              "edge/data-sync/schema-governance",
              "edge/data-sync/registry-coalescing",
              "edge/data-sync/backpressure"
            ]
          },
          {
            "group": "Edge agent (Omega)",
            "pages": [
              "edge/data-sync/omega-setup",
              "edge/data-sync/configuration",
              "edge/data-sync/capture-strategies",
              "edge/data-sync/provisioning-checklist"
            ]
          },
          {
            "group": "Operate & query",
            "pages": [
              "edge/data-sync/schema-review-workflow",
              "edge/data-sync/platform-tui-guide",
              "edge/data-sync/api-reference",
              "edge/data-sync/querying-data",
              "edge/data-sync/troubleshooting"
            ]
          },
          {
            "group": "Wire protocol reference",
            "pages": [
              "edge/data-sync/topics-and-connection",
              "edge/data-sync/payload-formats",
              "edge/data-sync/downlink-control",
              "edge/data-sync/limits-dedup-errors"
            ]
          }
        ]
      },
      {
        "tab": "Self-hosted",
        "groups": [
          {
            "group": "Deployment",
            "pages": [
              "self-hosted/overview",
              "self-hosted/vm-edge",
              "self-hosted/local-development"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "pages": [
          "api-reference/introduction",
          "api-reference/authentication"
        ],
        "openapi": "api-reference/ilyama.v1.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/golain-io/ilyama",
          "icon": "github"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@golain.io",
          "icon": "envelope"
        }
      ]
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude", "cursor", "mcp"]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/golain-io"
    }
  }
}
